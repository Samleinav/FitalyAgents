{
    "name": "fitalyagents",
    "version": "1.0.0",
    "description": "Multi-agent framework for async parallel tool orchestration and intelligent task dispatch",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./asynctools": {
            "import": "../asynctools/dist/index.mjs",
            "require": "../asynctools/dist/index.cjs",
            "types": "../asynctools/dist/index.d.ts"
        },
        "./dispatcher": {
            "import": "../dispatcher/dist/index.mjs",
            "require": "../dispatcher/dist/index.cjs",
            "types": "../dispatcher/dist/index.d.ts"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run --passWithNoTests",
        "lint": "eslint src/",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "agents",
        "async",
        "tools",
        "orchestration",
        "llm",
        "ai"
    ],
    "license": "SEE LICENSE IN LICENSE",
    "dependencies": {
        "ioredis": "^5.4.2",
        "zod": "^3.24.2"
    }
}