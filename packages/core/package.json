{
    "name": "fitalyagents",
    "version": "1.2.1",
    "description": "Multi-agent framework for async parallel tool orchestration and intelligent task dispatch",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run --passWithNoTests",
        "lint": "eslint src/",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "agents",
        "async",
        "tools",
        "orchestration",
        "llm",
        "ai"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/samleinav/FitalyAgents.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/samleinav/FitalyAgents#readme",
    "bugs": { "url": "https://github.com/samleinav/FitalyAgents/issues" },
    "license": "MIT",
    "dependencies": {
        "ioredis": "^5.4.2",
        "zod": "^3.24.2"
    }
}
