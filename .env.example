# ── FitalyAgents — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (for intent classification in fitaly-agent)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Store identifier
STORE_ID=store-001

# STT Whisper model: tiny(~39MB) | base(~74MB) | small(~244MB) | medium(~769MB)
# GPU (1660 Super): "small" is fast and accurate
# CPU fallback:     "tiny" is the only practical choice
STT_MODEL=small

# Force STT language (recommended — avoids auto-detect overhead)
# "es" = Spanish | "en" = English | leave empty for auto-detect
STT_LANGUAGE=es

# NeMo diarizer model (default is the 4-speaker streaming model)
DIARIZER_MODEL=diar_streaming_sortformer_4spk-v2.1

# NeMo speaker embedder model
EMBEDDER_MODEL=titanet_large

# ── GPU setup checklist (GTX 1660 Super / Turing) ────────────────────────────
#
# 1. Install NVIDIA Container Toolkit on Windows (WSL2):
#    https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
#    (Docker Desktop automatically picks it up via WSL2)
#
# 2. Verify GPU is visible to Docker:
#    docker run --rm --gpus all nvidia/cuda:12.1.1-base-ubuntu22.04 nvidia-smi
#
# 3. Start the full stack:
#    docker compose up --build
#
# ── Mic audio bridge (runs natively — 30-line script, no pipeline logic) ─────
#
# The fitaly-voice container receives mic audio via UDP on port 5005.
# Run this on your Windows host after docker compose up:
#
#   pip install sounddevice numpy   (one-time)
#   python audio_bridge.py          (streams mic → Docker container)
#
# List available microphones:
#   python audio_bridge.py --list-devices
#
# Use a specific mic:
#   python audio_bridge.py --device 1
